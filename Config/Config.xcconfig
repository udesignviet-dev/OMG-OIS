// Real config used to build the app.
// You can override MHM_API_BASE_URL / GOONG_API_KEY via GitHub Secrets in CI.
// The `/$()/` trick in the URL is required because xcconfig treats `//` as a comment.
MHM_API_BASE_URL = https:/$()/example.com/wp-json/mhm/v1
GOONG_API_KEY = REPLACE_WITH_YOUR_GOONG_API_KEY
PRODUCT_BUNDLE_IDENTIFIER = com.mulehazardmap.app
